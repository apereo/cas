{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "America/Los_Angeles",
  "extends": [
    ":dependencyDashboard",
    ":preserveSemverRanges",
    ":disableRateLimiting",
    ":semanticCommits",
    ":semanticCommitTypeAll(renovatebot)",
    "group:monorepos",
    "group:recommended",
    "replacements:all",
    "workarounds:all"
  ],
  "enabledManagers": [
    "gradle",
    "npm",
    "custom.regex",
    "dockerfile",
    "docker-compose",
    "github-actions"
  ],
  "rebaseWhen": "behind-base-branch",
  "automerge": false,
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["run-.*\\.sh$"],
      "matchStrings": [
        "export\\s+DOCKER_IMAGE\\s*=\\s*\"(?<depName>[^\"]+):(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": [".github/workflows/.*\\.yml$"],
      "matchStrings": [
        "NODE_CURRENT:\\s*'(?<currentValue>\\d+\\.\\d+\\.\\d+)'"
      ],
      "datasourceTemplate": "node",
      "depNameTemplate": "node",
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "fileMatch": [".github/workflows/.*\\.yml$"],
      "matchStrings": [
        "PYTHON_VERSION:\\s*'(?<currentValue>\\d+\\.\\d+\\.\\d+)'"
      ],
      "datasourceTemplate": "pypi",
      "depNameTemplate": "python",
      "versioningTemplate": "pep440"
    },
    {
      "customType": "regex",
      "fileMatch": [".github/workflows/.*\\.yml$"],
      "matchStrings": [
        "RUBY_VERSION:\\s*'(?<currentValue>\\d+\\.\\d+\\.\\d+)'"
      ],
      "datasourceTemplate": "ruby-version",
      "depNameTemplate": "ruby",
      "versioningTemplate": "semver"
    }
  ],
  "labels": ["Bot", "Renovate"],
  "schedule": [
    "after 5pm",
    "before 9am"
  ],
  "gradle": {
    "enabled": true
  },
  "dockerfile": {
    "enabled": true
  },
  "docker-compose": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchCategories": ["docker"],
      "enabled": true
    },
    {
      "matchPackageNames": ["com.google.guava:guava"],
      "excludeVersions": "/-android$/"
    },
    {
      "matchPackageNames": ["/^software\\.amazon\\.awssdk:.*/"],
      "matchUpdateTypes": ["major", "minor"]
    },
    {
      "matchPackageNames": ["com.h2database:h2"],
      "enabled": false
    },
    {
      "matchManagers": ["dockerfile"],
      "matchFileNames": ["**/oidc-login-strapi/**"],
      "matchPackageNames": ["node"],
      "enabled": false
    },
    {
      "matchFileNames": ["**/radius*/build.gradle"],
      "matchPackageNames": ["org.bouncycastle:bcprov-jdk15on"],
      "enabled": false
    }
  ]
}
