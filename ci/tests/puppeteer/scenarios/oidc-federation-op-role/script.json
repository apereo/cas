{
  "dependencies": "oidc,oidc-federation",
  "properties": [
    "--cas.server.name=https://localhost:8443",
    "--cas.server.prefix=https://localhost:8443/cas",

    "--cas.authn.oidc.federation.role=OPENID_PROVIDER",
    "--cas.authn.oidc.jwks.file-system.jwks-file=file:${#systemProperties['java.io.tmpdir']}/tmpoidc.jwks",
    "--cas.authn.oidc.federation.jwks-file=file:${#systemProperties['java.io.tmpdir']}/tmpfederation.jwks",
    "--cas.authn.oidc.core.issuer=https://localhost:8443/cas/oidc",
    "--cas.authn.oidc.federation.authority-hints[0]=https://trustanchor"
  ]
}
